# ── Copy to .env and fill in. NEVER commit .env. ────────────────────────────
# Providers with no key listed here (Yahoo, Stooq, SEC EDGAR, GDELT, World Bank,
# NSE/BSE public endpoints) work without credentials. Adapters whose key is
# missing are simply skipped in fallback chains.

# Core
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/equity_research
REDIS_URL=redis://localhost:6379/0
API_KEYS=changeme-frontend-service-key        # comma-separated allowed X-API-Key values
ENV=dev                                        # dev | staging | prod
LOG_LEVEL=INFO

# CORS — REQUIRED in prod. Comma-separated exact frontend origin(s) the browser
# may call the API from. In dev all origins are allowed; leave blank locally.
# e.g. CORS_ORIGINS=https://meridian.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=

# Managed hosts (Render/Railway/Fly/Cloud Run) inject PORT automatically; the
# Dockerfile CMD already binds to it. Only set PORT if running bare uvicorn.
# PORT=8000

# LLM gateway (AI analysis engine) — https://openrouter.ai/keys
# NOTE: sk-or-v1-... keys are OpenRouter keys. If yours was ever shared or
# committed anywhere, rotate it immediately.
OPENROUTER_API_KEY=
LLM_MODEL_ANALYSIS=anthropic/claude-sonnet-4.5
LLM_MODEL_CLASSIFY=anthropic/claude-haiku-4.5

# Market & fundamentals data
ALPHA_VANTAGE_API_KEY=          # https://www.alphavantage.co/support/#api-key (25 req/day free)
FMP_API_KEY=                    # https://site.financialmodelingprep.com (free tier)
FINNHUB_API_KEY=                # https://finnhub.io (free tier)
POLYGON_API_KEY=                # https://polygon.io (free tier, US only)

# Macro
FRED_API_KEY=                   # https://fred.stlouisfed.org/docs/api/api_key.html

# News
NEWSAPI_API_KEY=                # https://newsapi.org (free tier)

# SEC EDGAR requires a declared User-Agent (no key)
SEC_EDGAR_USER_AGENT="EquityResearchPlatform your-email@example.com"
